{
  "version": 2,
  "name": "ogos-saas-api",
  "builds": [
    {
      "src": "app/main.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "python3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "app/main.py"
    },
    {
      "src": "/healthz",
      "dest": "app/main.py"
    },
    {
      "src": "/webhooks/(.*)",
      "dest": "app/main.py"
    },
    {
      "src": "/auth/(.*)",
      "dest": "app/main.py"
    },
    {
      "src": "/admin/(.*)",
      "dest": "app/main.py"
    },
    {
      "src": "/orders/(.*)",
      "dest": "app/main.py"
    },
    {
      "src": "/organizations/(.*)",
      "dest": "app/main.py"
    },
    {
      "src": "/invoices/(.*)",
      "dest": "app/main.py"
    },
    {
      "src": "/compliance/(.*)",
      "dest": "app/main.py"
    },
    {
      "src": "/credits/(.*)",
      "dest": "app/main.py"
    },
    {
      "src": "/legal/(.*)",
      "dest": "app/main.py"
    },
    {
      "src": "/ogos/(.*)",
      "dest": "app/main.py"
    },
    {
      "src": "/beer/(.*)",
      "dest": "app/main.py"
    }
  ],
  "env": {
    "PYTHONUNBUFFERED": "1"
  }
}
