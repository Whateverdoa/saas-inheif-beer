# ===========================================
# VERCEL DEPLOYMENT ENVIRONMENT VARIABLES
# ===========================================
# Copy these to your Vercel project settings
# Dashboard > Project > Settings > Environment Variables

# -------------------------------------------
# Stripe Configuration
# -------------------------------------------
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_API_KEY=sk_live_...

# -------------------------------------------
# Polar Configuration
# -------------------------------------------
POLAR_WEBHOOK_SECRET=your_polar_secret

# -------------------------------------------
# OGOS Configuration (Label Printing API)
# -------------------------------------------
OGOS_BASE_URL=https://orders.optimumgroup.nl/OrderService
OGOS_API_KEY=your_ogos_api_key
OGOS_MASTER_GUID=your_master_guid

# -------------------------------------------
# Clerk Authentication
# -------------------------------------------
CLERK_SECRET_KEY=sk_live_...
CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_FRONTEND_API=https://your-app.clerk.accounts.dev

# -------------------------------------------
# Database (for production, use external DB)
# -------------------------------------------
# Option 1: Vercel Postgres
# DATABASE_URL=postgres://...

# Option 2: Supabase
# DATABASE_URL=postgresql://...

# Option 3: PlanetScale
# DATABASE_URL=mysql://...

# -------------------------------------------
# Convex (Optional - for event store)
# -------------------------------------------
CONVEX_URL=https://your-project.convex.cloud
CONVEX_TOKEN=your_convex_token

# -------------------------------------------
# Beer Labels Feature
# -------------------------------------------
BEER_LABELS_ENABLED=true
BEER_COMPLIANCE_STRICT_MODE=true

# -------------------------------------------
# Frontend API URL (set in frontend project)
# -------------------------------------------
# NEXT_PUBLIC_API_URL=https://your-api.vercel.app
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
